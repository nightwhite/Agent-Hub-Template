{
  "script": "agents/hermes/config.sh",
  "zh": {
    "resources": [
      {
        "resource": "config",
        "label": "运行时配置",
        "description": "写入 .env 和默认模型配置，适合端点、密钥和主模型。",
        "actions": [
          {
            "action": "set",
            "label": "设置运行时配置",
            "args": [
              {
                "name": "endpoint",
                "label": "Base URL",
                "type": "text",
                "required": true,
                "placeholder": "http://xxx.xxx.xxx/v1"
              },
              {
                "name": "api_key",
                "label": "API Key",
                "type": "password",
                "required": true,
                "placeholder": "sk-xxxxxxxxxx"
              },
              {
                "name": "model",
                "label": "模型",
                "type": "text",
                "required": false,
                "default": "gpt-5.4"
              }
            ]
          },
          {
            "action": "get",
            "label": "读取运行时配置",
            "args": []
          },
          {
            "action": "list",
            "label": "列出运行时配置",
            "args": []
          },
          {
            "action": "delete",
            "label": "删除运行时配置",
            "args": []
          }
        ]
      },
      {
        "resource": "yaml",
        "label": "config.yaml 配置",
        "description": "维护 config.values.env、providers.list，并重渲染 config.yaml。",
        "actions": [
          {
            "action": "set",
            "label": "设置 YAML 标量字段",
            "args": [
              {
                "name": "key",
                "label": "配置项",
                "type": "select",
                "required": true,
                "options": [
                  "model",
                  "provider",
                  "terminal.backend",
                  "display.skin"
                ]
              },
              {
                "name": "value",
                "label": "值",
                "type": "text",
                "required": true
              }
            ]
          },
          {
            "action": "get",
            "label": "读取 YAML 字段",
            "args": [
              {
                "name": "key",
                "label": "配置项",
                "type": "select",
                "required": true,
                "options": [
                  "model",
                  "provider",
                  "terminal.backend",
                  "display.skin",
                  "fallback_providers"
                ]
              }
            ]
          },
          {
            "action": "delete",
            "label": "删除 YAML 字段",
            "args": [
              {
                "name": "key",
                "label": "配置项",
                "type": "select",
                "required": true,
                "options": [
                  "model",
                  "provider",
                  "terminal.backend",
                  "display.skin",
                  "fallback_providers"
                ]
              }
            ]
          },
          {
            "action": "list",
            "label": "查看完整 YAML",
            "args": []
          },
          {
            "action": "render",
            "label": "重渲染 config.yaml",
            "args": []
          },
          {
            "action": "add",
            "label": "添加 fallback provider",
            "args": [
              {
                "name": "key",
                "label": "目标项",
                "type": "fixed",
                "required": true,
                "value": "fallback_providers"
              },
              {
                "name": "value",
                "label": "Provider",
                "type": "text",
                "required": true,
                "placeholder": "openai"
              }
            ]
          },
          {
            "action": "remove",
            "label": "移除 fallback provider",
            "args": [
              {
                "name": "key",
                "label": "目标项",
                "type": "fixed",
                "required": true,
                "value": "fallback_providers"
              },
              {
                "name": "value",
                "label": "Provider",
                "type": "text",
                "required": true,
                "placeholder": "openai"
              }
            ]
          },
          {
            "action": "add",
            "label": "添加 provider",
            "args": [
              {
                "name": "key",
                "label": "目标项",
                "type": "fixed",
                "required": true,
                "value": "provider"
              },
              {
                "name": "name",
                "label": "Provider 名称",
                "type": "text",
                "required": true,
                "placeholder": "custom"
              },
              {
                "name": "base_url",
                "label": "Base URL",
                "type": "text",
                "required": false,
                "placeholder": "http://xxx.xxx.xxx/v1"
              },
              {
                "name": "api_key_env",
                "label": "API Key 环境变量",
                "type": "text",
                "required": false,
                "default": "OPENAI_API_KEY"
              }
            ]
          },
          {
            "action": "remove",
            "label": "移除 provider",
            "args": [
              {
                "name": "key",
                "label": "目标项",
                "type": "fixed",
                "required": true,
                "value": "provider"
              },
              {
                "name": "name",
                "label": "Provider 名称",
                "type": "text",
                "required": true,
                "placeholder": "custom"
              }
            ]
          }
        ]
      }
    ]
  },
