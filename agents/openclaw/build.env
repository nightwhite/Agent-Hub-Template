AGENT_NAME=openclaw
AGENT_RUNTIME_KIND=service
NODE_MAJOR=22
# Latest npm-published OpenClaw release verified on 2026-04-24.
# reference/openclaw HEAD is 12de62bfd831eac9ce4a1087542ab6a1ef02d120 and
# reports package.json version 2026.4.23, but that version is not published to npm yet.
OPENCLAW_VERSION=2026.4.22
OPENCLAW_UPSTREAM_REF=12de62bfd831eac9ce4a1087542ab6a1ef02d120
OPENCLAW_STATE_DIR=/home/agent/.openclaw
OPENCLAW_CONFIG_PATH=/home/agent/.openclaw/openclaw.json
OPENCLAW_WORKSPACE=/workspace
OPENCLAW_GATEWAY_TOKEN=change-me-local-dev
